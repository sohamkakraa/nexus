{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.sohamkakra.com/schemas/release-manifest-v1.json",
  "title": "Nexus release manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "fallbackUrl",
    "release"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "fallbackUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://github\\.com/sohamkakraa/nexus/releases(?:/.*)?$"
    },
    "release": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/release"
        }
      ]
    }
  },
  "$defs": {
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "channel",
        "publishedAt",
        "releaseUrl",
        "checksumsUrl",
        "assets"
      ],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$"
        },
        "channel": {
          "enum": [
            "stable",
            "prerelease"
          ]
        },
        "publishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "releaseUrl": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://github\\.com/sohamkakraa/nexus/releases/tag/v"
        },
        "checksumsUrl": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://github\\.com/sohamkakraa/nexus/releases/download/v"
        },
        "assets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/asset"
          },
          "minItems": 1
        }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "architecture",
        "format",
        "fileName",
        "url",
        "sizeBytes",
        "sha256",
        "systemRequirements",
        "installInstructions",
        "signing"
      ],
      "properties": {
        "platform": {
          "enum": [
            "macos",
            "windows",
            "linux"
          ]
        },
        "architecture": {
          "enum": [
            "arm64",
            "x64"
          ]
        },
        "format": {
          "enum": [
            "dmg",
            "zip",
            "nsis",
            "appimage",
            "deb"
          ]
        },
        "fileName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 180,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]+$"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://github\\.com/sohamkakraa/nexus/releases/download/v"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "systemRequirements": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "installInstructions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          }
        },
        "signing": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "label"
          ],
          "properties": {
            "status": {
              "enum": [
                "notarized",
                "signed",
                "unsigned"
              ]
            },
            "label": {
              "type": "string",
              "minLength": 1,
              "maxLength": 180
            }
          }
        }
      }
    }
  }
}
